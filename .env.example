# Discovery sources — set at least one
# Google Places (paid; $200/mo free credit): https://developers.google.com/maps/documentation/places/web-service
GOOGLE_PLACES_API_KEY=

# Brave Search API (2,000 queries/mo free): https://brave.com/search/api/
BRAVE_SEARCH_API_KEY=

# URL harvester search backend: brave | duckduckgo | searxng
# - brave: requires BRAVE_SEARCH_API_KEY above
# - duckduckgo: no key, but fragile HTML scrape; rate-limited if abused
# - searxng: self-hosted; the bundled docker-compose service runs at
#   http://searxng:8080 (in-network) and http://localhost:8081 (host)
SEARCH_PROVIDER=brave
SEARXNG_URL=http://searxng:8080
# Set to any long random string before exposing SearXNG beyond localhost
SEARXNG_SECRET=change-me-please

# OpenStreetMap Overpass requires no key (free, rate-limited)

# Optional: Bing Search API for SERP enrichment (~$7/mo for 1k calls)
BING_SEARCH_API_KEY=

# Optional: Apollo.io enrichment (50 free exports/mo)
APOLLO_API_KEY=

# Optional: Hunter.io enrichment (25 free searches/mo)
HUNTER_API_KEY=

# Database — SQLite by default; swap URL for Postgres
DATABASE_URL=sqlite+aiosqlite:////data/leadgen.db
# DATABASE_URL=postgresql+asyncpg://user:password@host:5432/leadgen

# Scraping
MAX_CONCURRENT_SCRAPE_REQUESTS=5
REQUEST_DELAY_SECONDS=1.0
REQUEST_TIMEOUT_SECONDS=10
RESPECT_ROBOTS_TXT=true
MAX_CONTACT_PAGES_PER_SITE=3

CORS_ORIGINS=["http://localhost:3000"]
LOG_LEVEL=INFO
