# Required
GOOGLE_PLACES_API_KEY=

# Optional enrichment
BING_SEARCH_API_KEY=
APOLLO_API_KEY=
HUNTER_API_KEY=

# Database (SQLite default; swap for Postgres)
DATABASE_URL=sqlite+aiosqlite:////data/leadgen.db
# DATABASE_URL=postgresql+asyncpg://user:password@host:5432/leadgen

# Scraping tuning
MAX_CONCURRENT_SCRAPE_REQUESTS=5
REQUEST_DELAY_SECONDS=1.0
REQUEST_TIMEOUT_SECONDS=10
RESPECT_ROBOTS_TXT=true
MAX_CONTACT_PAGES_PER_SITE=3

CORS_ORIGINS=["http://localhost:3000"]
LOG_LEVEL=INFO
