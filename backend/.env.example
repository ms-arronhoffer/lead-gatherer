# Required
GOOGLE_PLACES_API_KEY=

# Optional enrichment
BRAVE_SEARCH_API_KEY=
BING_SEARCH_API_KEY=
APOLLO_API_KEY=
HUNTER_API_KEY=

# URL harvester search backend: brave | duckduckgo | searxng
# - brave: requires BRAVE_SEARCH_API_KEY (2,000 queries/mo free)
# - duckduckgo: no key, but fragile HTML scrape; rate-limited if abused
# - searxng: self-hosted; the bundled docker-compose service runs at
#   http://searxng:8080 (in-network) and http://localhost:8081 (host)
SEARCH_PROVIDER=brave
SEARXNG_URL=http://searxng:8080
SEARXNG_SECRET=change-me-please

# Database (SQLite default; swap for Postgres)
DATABASE_URL=sqlite+aiosqlite:////data/leadgen.db
# DATABASE_URL=postgresql+asyncpg://user:password@host:5432/leadgen
REDIS_URL=redis://redis:6379/0

# Scraping tuning
MAX_CONCURRENT_SCRAPE_REQUESTS=5
REQUEST_DELAY_SECONDS=1.0
REQUEST_TIMEOUT_SECONDS=10
RESPECT_ROBOTS_TXT=true
MAX_CONTACT_PAGES_PER_SITE=3
SCRAPE_MAX_RETRIES=2
# Recent news / press-release enrichment (uses SEARCH_PROVIDER + LLM)
ENABLE_NEWS_ENRICHMENT=false
MAX_NEWS_ARTICLES=3

CORS_ORIGINS=["http://localhost:3000"]
LOG_LEVEL=INFO

# Entra ID (Azure AD) — set both to enforce auth.
# Leave DEV_BYPASS_AUTH=true while developing without an app registration.
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
DEV_BYPASS_AUTH=true

# LLM provider: azure_openai | ollama | anthropic | google
LLM_PROVIDER=ollama

# Azure OpenAI
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=2024-08-01-preview

# Ollama
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.1:8b

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5

# Google Gemini
GOOGLE_API_KEY=
GOOGLE_MODEL=gemini-2.0-flash

# Microsoft Graph
GRAPH_BASE_URL=https://graph.microsoft.com/v1.0

# Visitor pixel
PIXEL_ORIGINS=["*"]
IP2ASN_DB_PATH=/data/IP2LOCATION-LITE-ASN.CSV

# Sequence sender
SEQUENCE_SEND_BATCH=50

# Lead scoring / buying-signal layer
# Max fit_score for a lead without a deliverable email AND a normalized phone.
FIT_UNREACHABLE_CAP=79
# priority = fit_weight*fit + intent_weight*intent (then freshness decay).
PRIORITY_FIT_WEIGHT=0.6
PRIORITY_INTENT_WEIGHT=0.4
# Days of no activity after which a lead's priority halves.
FRESHNESS_HALF_LIFE_DAYS=60
# priority_score at/above which a lead is "hot" and fires the lead.hot webhook.
HOT_LEAD_THRESHOLD=80
# Days after which a single buying signal's strength halves.
SIGNAL_HALF_LIFE_DAYS=45

